# =============================================================================
# AI-OS — Environment Variables (example only — copy to .env and fill in)
# =============================================================================
# Never commit .env or real secrets. This file documents likely variables
# for a personal AI operating system platform.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
AI_OS_ENV=development
# development | staging | production
AI_OS_DEBUG=false
AI_OS_LOG_LEVEL=info
# debug | info | warn | error
AI_OS_DATA_DIR=./memory
AI_OS_CONFIG_PATH=./config

# -----------------------------------------------------------------------------
# Server / API (when runtime is added)
# -----------------------------------------------------------------------------
AI_OS_HOST=127.0.0.1
AI_OS_PORT=8080
AI_OS_PUBLIC_URL=http://localhost:8080
AI_OS_CORS_ORIGINS=http://localhost:3000,http://localhost:8080
AI_OS_API_KEY=
# Optional API key for securing local or deployed AI-OS endpoints

# -----------------------------------------------------------------------------
# LLM Providers
# -----------------------------------------------------------------------------
# OpenAI
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=
OPENAI_DEFAULT_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE=https://api.anthropic.com
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514

# Google (Gemini)
GOOGLE_API_KEY=
GOOGLE_DEFAULT_MODEL=gemini-2.0-flash

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT_NAME=

# AWS Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BEDROCK_MODEL_ID=

# Local / Ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_DEFAULT_MODEL=llama3.2

# Groq, Together, Mistral, Cohere (optional)
GROQ_API_KEY=
TOGETHER_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=

# -----------------------------------------------------------------------------
# Embeddings
# -----------------------------------------------------------------------------
EMBEDDING_PROVIDER=ollama
# openai | anthropic | local | ollama | huggingface
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768
EMBEDDING_BATCH_SIZE=100

# -----------------------------------------------------------------------------
# Vector / semantic search
# -----------------------------------------------------------------------------
VECTOR_STORE=chroma
# local | chroma | qdrant | weaviate | pinecone | pgvector | lancedb
VECTOR_STORE_PATH=./knowledge/index
CHROMA_HOST=localhost
CHROMA_PORT=8000
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=ai-os

# -----------------------------------------------------------------------------
# Databases
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///./memory/ai-os.db
# postgres://user:pass@localhost:5432/ai_os
REDIS_URL=redis://localhost:6379/0
MONGODB_URI=mongodb://localhost:27017/ai_os

# -----------------------------------------------------------------------------
# Knowledge pipeline
# -----------------------------------------------------------------------------
KNOWLEDGE_RAW_DIR=./knowledge/raw
KNOWLEDGE_PROCESSED_DIR=./knowledge/processed
KNOWLEDGE_INDEX_DIR=./knowledge/index
KNOWLEDGE_CHUNK_SIZE=512
KNOWLEDGE_CHUNK_OVERLAP=64
KNOWLEDGE_MAX_FILE_SIZE_MB=50

# -----------------------------------------------------------------------------
# Memory layer
# -----------------------------------------------------------------------------
MEMORY_BACKEND=file
# file | sqlite | redis | postgres
MEMORY_WORKING_DIR=./memory/working
MEMORY_EPISODIC_DIR=./memory/episodic
MEMORY_SEMANTIC_DIR=./memory/semantic
MEMORY_PROCEDURAL_DIR=./memory/procedural
MEMORY_RETENTION_DAYS=90
MEMORY_WORKING_TTL_MINUTES=60
MEMORY_MAX_RETRIEVAL_ITEMS=10
MEMORY_MAX_TOKENS=128000
MEMORY_SUMMARIZE_THRESHOLD=100000

# -----------------------------------------------------------------------------
# Decision engine
# -----------------------------------------------------------------------------
DECISION_ENGINE_DEFAULT_TEMPERATURE=0.2
DECISION_ENGINE_MAX_TOKENS=4096
DECISION_ENGINE_TIMEOUT_SECONDS=120
DECISION_ENGINE_PROMPTS_DIR=./decision-engine/prompts
DECISION_ENGINE_TEMPLATES_DIR=./decision-engine/templates
DECISION_ENGINE_DECISIONS_DIR=./memory/decisions
DECISION_ENGINE_DEFAULT_STRATEGY=analytical
DECISION_ENGINE_USE_LLM=true

# -----------------------------------------------------------------------------
# Agent runtime
# -----------------------------------------------------------------------------
AGENT_TASKS_DIR=./memory/agent/tasks
AGENT_LOGS_DIR=./memory/agent/logs
AGENT_WORKFLOWS_DIR=./config/workflows
AGENT_DEFINITIONS_DIR=./config/agents
AGENT_DEFAULT_MAX_RETRIES=3
AGENT_SHELL_ENABLED=false
AGENT_HTTP_ENABLED=true
JWT_SECRET=
JWT_EXPIRY_HOURS=24
SESSION_SECRET=
ENCRYPTION_KEY=
# 32-byte key for encrypting sensitive memory at rest (base64 or hex)

# -----------------------------------------------------------------------------
# OAuth (optional)
# -----------------------------------------------------------------------------
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=ai-os
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ai-os
WANDB_API_KEY=
WANDB_PROJECT=ai-os

# -----------------------------------------------------------------------------
# Object storage (optional — for large artifacts)
# -----------------------------------------------------------------------------
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
# For MinIO / compatible: http://localhost:9000

# -----------------------------------------------------------------------------
# Email / notifications (optional)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
FEATURE_EXPERIMENTS_ENABLED=true
FEATURE_WEB_UI=false
FEATURE_AUTO_INDEX=true
FEATURE_MEMORY_SUMMARIZATION=true

# -----------------------------------------------------------------------------
# Rate limiting & quotas
# -----------------------------------------------------------------------------
RATE_LIMIT_REQUESTS_PER_MINUTE=60
MAX_CONCURRENT_LLM_REQUESTS=5
MONTHLY_LLM_BUDGET_USD=
