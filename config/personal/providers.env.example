# =============================================================================
# AI-OS — Personal Provider Configuration (EXAMPLE VALUES ONLY)
# =============================================================================
# Copy relevant sections into your .env file. Never commit .env.
# Full setup instructions: docs/personal/provider-configuration.md
# =============================================================================

# -----------------------------------------------------------------------------
# Ollama (local — start here, no API key required)
# -----------------------------------------------------------------------------
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_DEFAULT_MODEL=llama3.2
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text

# -----------------------------------------------------------------------------
# GitHub
# Obtain: https://github.com/settings/tokens → Fine-grained or classic PAT
# Scopes: repo (read), read:user
# -----------------------------------------------------------------------------
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# OpenAI
# Obtain: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o

# -----------------------------------------------------------------------------
# Anthropic
# Obtain: https://console.anthropic.com/settings/keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514

# -----------------------------------------------------------------------------
# Gemini (Google AI Studio — separate from Gmail/Calendar OAuth)
# Obtain: https://aistudio.google.com/apikey
# -----------------------------------------------------------------------------
GOOGLE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_DEFAULT_MODEL=gemini-2.0-flash

# -----------------------------------------------------------------------------
# OpenRouter (multi-model gateway)
# Obtain: https://openrouter.ai/keys
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Google Workspace (Gmail, Calendar, Drive)
# One access token covers all three providers in AI-OS.
#
# Obtain via Google Cloud Console:
#   1. Create project → APIs & Services → Enable:
#      - Gmail API
#      - Google Calendar API
#      - Google Drive API
#   2. OAuth consent screen (External, add your email as test user)
#   3. Credentials → OAuth 2.0 Client ID (Desktop app)
#   4. Run OAuth flow once to get refresh token, then exchange for access token
#
# Short-term: paste a fresh access token (expires ~1 hour)
# Long-term: store refresh token and automate refresh (v1.2 roadmap)
# -----------------------------------------------------------------------------
GOOGLE_ACCESS_TOKEN=ya29.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OAuth client IDs (for future refresh automation — optional for health checks today)
GMAIL_CLIENT_ID=123456789012-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_CALENDAR_CLIENT_ID=123456789012-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CALENDAR_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_DRIVE_CLIENT_ID=123456789012-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_DRIVE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Model routing (recommended for daily use)
# -----------------------------------------------------------------------------
MODEL_ROUTER_DEFAULT_PROVIDER=ollama
MODEL_ROUTER_FALLBACK_CHAIN=ollama,openai,anthropic,gemini,openrouter
MODEL_ROUTER_PREFER_LOCAL=true
INTEGRATION_HEALTH_TIMEOUT_SECONDS=10.0
INTEGRATION_RETRY_ATTEMPTS=3
